# ============================================
# 🔥 .HTACCESS — АЛМИК | ГРУЗОПЕРЕВОЗКИ РФ И СНГ
# ============================================
# Версия: 3.0 ULTIMATE
# Сайт: https://almik-logistic.ru
# Компания: ООО «АЛМИК»
# Обновлено: 2026-05-18
# ============================================
# ✅ HTTPS + www → без www
# ✅ Старый домен → новый (onrender.com → almik-logistic.ru)
# ✅ SPA-роутинг для React
# ✅ Сжатие Brotli + Gzip
# ✅ Кэш на год для статики
# ✅ Защита от ботов и парсеров
# ✅ Безопасность: XSS, MIME-sniffing, clickjacking
# ✅ Чистые URL без слешей и index.html
# ============================================

# ──────────────────────────────────────────
# 1. КОДИРОВКА ПО УМОЛЧАНИЮ
# ──────────────────────────────────────────
AddDefaultCharset UTF-8

# ──────────────────────────────────────────
# 2. ЗАПРЕТ ПРОСМОТРА СОДЕРЖИМОГО ПАПОК
# ──────────────────────────────────────────
Options All -Indexes

# ──────────────────────────────────────────
# 3. СЖАТИЕ BROTLI (САМОЕ СИЛЬНОЕ)
# ──────────────────────────────────────────
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css text/javascript text/xml application/json application/javascript application/xml application/rss+xml application/atom+xml image/svg+xml font/woff font/woff2 application/vnd.ms-fontobject
</IfModule>

# ──────────────────────────────────────────
# 4. СЖАТИЕ GZIP (ЗАПАСНОЕ)
# ──────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript text/xml application/json application/javascript application/xml application/rss+xml application/atom+xml image/svg+xml font/woff font/woff2 application/vnd.ms-fontobject application/x-font-ttf
</IfModule>

# ──────────────────────────────────────────
# 5. КЭШИРОВАНИЕ (МАКСИМАЛЬНОЕ)
# ──────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # Шрифты — 1 год
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/vnd.ms-fontobject "access plus 1 year"
  ExpiresByType application/x-font-ttf "access plus 1 year"

  # Картинки — 1 год
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/ico "access plus 1 year"

  # CSS и JS — 1 месяц
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"

  # HTML — без кэша (всегда свежий)
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ──────────────────────────────────────────
# 6. ЗАГОЛОВКИ КЭША ДЛЯ СТАТИКИ
# ──────────────────────────────────────────
<FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico|css|js|woff|woff2|ttf|eot)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# ──────────────────────────────────────────
# 7. БЕЗОПАСНОСТЬ (ЗАЩИТА ОТ ВЗЛОМА)
# ──────────────────────────────────────────
<IfModule mod_headers.c>
  # Защита от XSS-атак
  Header set X-XSS-Protection "1; mode=block"

  # Защита от MIME-sniffing
  Header set X-Content-Type-Options "nosniff"

  # Защита от clickjacking
  Header set X-Frame-Options "SAMEORIGIN"

  # Политика реферера (не передавать лишнее)
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  # Убираем информацию о сервере
  Header unset Server
  Header unset X-Powered-By
</IfModule>

# ──────────────────────────────────────────
# 8. ЗАЩИТА ОТ БОТОВ И ПАРСЕРОВ
# ──────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Блокировка по User-Agent (парсеры, боты, скрипты)
  RewriteCond %{HTTP_USER_AGENT} (AhrefsBot|SemrushBot|MJ12bot|DotBot|PetalBot|Bytespider|BLEXBot|ZoominfoBot|DataForSeoBot|SerpstatBot|Screaming\ Frog|SiteAuditBot|SeznamBot|rogerbot|Exabot|spbot|YisouSpider|Sogou\ Spider|Baiduspider|MegaIndex|LinkpadBot|XoviBot|Sistrix|CCBot|GPTBot|ChatGPT|anthropic-ai|Claude-Web|PerplexityBot|Netcraft|Nmap|Nikto|OpenVAS|sqlmap|w3af|Zgrab|masscan|python-requests|libwww-perl|curl|wget|HTTrack|WebCopier|SiteSucker|Offline\ Explorer|Teleport\ Pro|WebZIP) [NC]
  RewriteRule .* - [F,L]

  # Блокировка по IP (если есть конкретные враги — добавь сюда)
  # RewriteCond %{REMOTE_ADDR} ^123\.456\.789\. [OR]
  # RewriteRule .* - [F,L]
</IfModule>

# ──────────────────────────────────────────
# 9. РЕДИРЕКТЫ (SEO-СКЛЕЙКА ДУБЛЕЙ)
# ──────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On

  # HTTP → HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

  # www → без www
  RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
  RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

  # Старый домен → новый
  RewriteCond %{HTTP_HOST} ^almik\.onrender\.com$ [NC,OR]
  RewriteCond %{HTTP_HOST} ^www\.almik\.onrender\.com$ [NC]
  RewriteRule ^(.*)$ https://almik-logistic.ru/$1 [R=301,L]

  # index.html → корень
  RewriteRule ^index\.html$ / [R=301,L]

  # Убираем слеш в конце (кроме корня)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} (.+)/$
  RewriteRule ^ %1 [R=301,L]

  # ВСЕ URL в нижний регистр
  RewriteMap lowercase int:tolower
  RewriteCond %{REQUEST_URI} [A-Z]
  RewriteRule ^(.*)$ ${lowercase:$1} [R=301,L]
</IfModule>

# ──────────────────────────────────────────
# 10. SPA-РОУТИНГ ДЛЯ REACT
# ──────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# ──────────────────────────────────────────
# 11. ЗАЩИТА СЛУЖЕБНЫХ ФАЙЛОВ
# ──────────────────────────────────────────
<FilesMatch "\.(env|json|log|md|yml|yaml|lock|sql|tar|gz|zip|rar)$">
  Order allow,deny
  Deny from all
</FilesMatch>

<FilesMatch "(package\.json|package-lock\.json|yarn\.lock|composer\.json|composer\.lock|Dockerfile|docker-compose\.yml|README\.md|CHANGELOG\.md|LICENSE)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# Защита .htaccess самого себя
<Files .htaccess>
  Order allow,deny
  Deny from all
</Files>

# ──────────────────────────────────────────
# 12. СТРАНИЦЫ ОШИБОК
# ──────────────────────────────────────────
ErrorDocument 400 /index.html
ErrorDocument 401 /index.html
ErrorDocument 403 /index.html
ErrorDocument 404 /index.html
ErrorDocument 500 /index.html
ErrorDocument 503 /index.html

# ──────────────────────────────────────────
# 13. СЖАТИЕ ФАЙЛОВ БЕЗ MOD_DEFLATE
# ──────────────────────────────────────────
<IfModule mod_filter.c>
  FilterDeclare COMPRESS
  FilterProvider COMPRESS DEFLATE "%{CONTENT_TYPE} =~ m|^text/|"
  FilterProvider COMPRESS DEFLATE "%{CONTENT_TYPE} =~ m|^application/(javascript|json|xml|x-javascript)|"
  FilterProvider COMPRESS DEFLATE "%{CONTENT_TYPE} =~ m|^image/svg\+xml|"
  FilterChain COMPRESS
  FilterProtocol COMPRESS DEFLATE change=yes;byteranges=no
</IfModule>

# ──────────────────────────────────────────
# 14. ДОПОЛНИТЕЛЬНЫЕ MIME-ТИПЫ
# ──────────────────────────────────────────
AddType image/webp .webp
AddType image/svg+xml .svg
AddType font/woff .woff
AddType font/woff2 .woff2
AddType application/vnd.ms-fontobject .eot
AddType application/x-font-ttf .ttf

# ──────────────────────────────────────────
# 15. ОТКЛЮЧАЕМ ETag (ИСПОЛЬЗУЕМ Cache-Control)
# ──────────────────────────────────────────
<IfModule mod_headers.c>
  Header unset ETag
  FileETag None
</IfModule>

# ──────────────────────────────────────────
# 🔥 КОНЕЦ ФАЙЛА — ТЫ КРУТ!
# ──────────────────────────────────────────